{
  "name": "fetchwatch",
  "version": "1.0.0",
  "description": "Poll a copied cURL or fetch request and get notified when the response changes",
  "type": "module",
  "bin": {
    "fetchwatch": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=21"
  },
  "keywords": [
    "cli",
    "curl",
    "fetch",
    "poll",
    "watch",
    "diff",
    "notification"
  ],
  "license": "MIT",
  "dependencies": {
    "node-notifier": "^10.0.1",
    "picocolors": "^1.1.1",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/node-notifier": "^8.0.5",
    "@types/prompts": "^2.4.9",
    "typescript": "^5.7.2"
  }
}
